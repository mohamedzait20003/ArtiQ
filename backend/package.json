{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend services for ECE 30816 Project",
  "scripts": {
    "migrate": "python scripts/migrate.py",
    "migrate:rollback": "python scripts/migrate.py --rollback",
    "migrate:status": "python scripts/migrate.py --status",
    "seed": "python scripts/seed.py",
    "seed:force": "python scripts/seed.py --force",
    "db:fresh": "python scripts/db.py fresh",
    "db:reset": "python scripts/db.py reset",
    "generate:salt": "python scripts/generate_salt.py",
    "generate:key": "python scripts/generate_key.py",
    "lambda:dev": "cd services/lambda-service; uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "lambda:test": "cd services/lambda-service; pytest",
    "lambda:test:coverage": "cd services/lambda-service; pytest --cov=app --cov-report=html",
    "lambda:build": "cd services/lambda-service; sam build",
    "lambda:deploy": "cd services/lambda-service; sam deploy",
    "lambda:local": "cd services/lambda-service; sam local start-api",
    "fargate:dev": "cd services/fargate-service; uvicorn src.main:app --reload --host 0.0.0.0 --port 8001"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [
    "fastapi",
    "aws",
    "lambda",
    "fargate",
    "documentdb"
  ],
  "author": "Team 25",
  "license": "ISC"
}
